{
  "name": "hotel-booking-engine",
  "version": "1.0.0",
  "description": "Complete Hotel Booking Engine with Admin Panel and OTA Sync",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "server": "nodemon server.js",
    "build": "cd client && npm run build",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "nodemailer": "^6.9.4",
    "moment": "^2.29.4",
    "xml2js": "^0.6.2",
    "axios": "^1.5.0",
    "uuid": "^9.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": ["hotel", "booking", "engine", "OTA", "sync"],
  "author": "Hotel Booking System",
  "license": "MIT"
}